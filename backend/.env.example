# Dubai Pulse / DLD open data — apply at https://www.dubaipulse.gov.ae
# Leave blank to run the API in sample-data mode (valuation/properties endpoints
# will serve the bundled sample dataset instead of erroring out).
DUBAI_PULSE_CLIENT_ID=
DUBAI_PULSE_CLIENT_SECRET=
DUBAI_PULSE_TOKEN_URL=
DUBAI_PULSE_TRANSACTIONS_URL=

# Geoapify — free tier at https://www.geoapify.com (geocoding + POI fallback)
GEOAPIFY_API_KEY=

# Comma-separated list of origins allowed to call this API
CORS_ORIGINS=http://localhost:3000
